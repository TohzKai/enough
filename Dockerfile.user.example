# loom dev-container distribution source (py) — generated INTO consumer templates by /sync-to-use; do not hand-edit the consumer copy. Registry host/org are ecosystem-relative, substituted at /sync-to-use distribution.
# Project-owned image layer — copy to `Dockerfile.user` to activate.
#
#     cp Dockerfile.user.example Dockerfile.user
#
# This is the ONE documented case where the "no rebuild" promise does NOT hold: extra OS
# packages (apt) require a rebuild. The base image ships NO passwordless sudo (security, H3),
# so OS packages are added by building a thin layer FROM the published base — NOT by
# `sudo apt` inside a running container. pip and Node deps stay no-rebuild (use
# requirements-user.txt / package.json + postCreate.sh).
#
# Your `Dockerfile.user` is project-owned and survives /sync; this `.example` is
# consumer-shipped (regenerated by /sync).
#
# ── Build & wire it ────────────────────────────────────────────────────────────────
#   1. The base image is published — no local build needed. Optionally pre-pull
#      (use the published reference printed in your README / devcontainer.json):
#        docker pull <registry-host>/<registry-org>/kailash-coc-py:1.10.1
#   2. Build your layer:
#        docker build -f Dockerfile.user -t kailash-coc-dev:myproject .
#   3. Point Compose at it (in compose.override.yml):
#        services:
#          dev:
#            image: kailash-coc-dev:myproject
#      …then `./bin/dev` uses your image. (Devcontainer: set "image" in devcontainer.json
#      to "kailash-coc-dev:myproject" instead of the published image.)
#
# ── Tag-pin discipline (post-pivot R-B1) ───────────────────────────────────────────
#   Per specs/dev-container-image.md § Reproducibility + plan §11 R-B1: derivative
#   `Dockerfile.user FROM …` references MUST pin the registry tag at a specific
#   digest. `:latest` (or bare `:<X.Y.Z>`) is a moving pointer suitable for `bin/dev`
#   ergonomics, NOT for derivative builds — a silent base-image revision would change
#   your derivative's bytes between rebuilds. Resolve the digest for the tag you want
#   to pin to via:
#        docker manifest inspect <registry-host>/<registry-org>/kailash-coc-py:1.10.1
#   …and substitute it below in place of `<digest>` BEFORE running `docker build`.
#   Bump both the tag and the digest together on each base-image upgrade.

# Replace <registry-host>/<registry-org> with the published reference for your ecosystem
# (the same one printed in your README / .devcontainer/devcontainer.json):
FROM <registry-host>/<registry-org>/kailash-coc-py:1.10.1@sha256:<digest>
# Tag-only form — accepts the moving-pointer trade-off; NOT spec-compliant for derivative builds.
# Use only if you understand and accept R-B1 tag-trust drift (rebuilds may pull a different base):
# FROM <registry-host>/<registry-org>/kailash-coc-py:1.10.1

# OS packages need root; the base runs as the non-root `dev` user, so switch to root for the
# install, then switch back. Keep `dev` as the final user (file ownership / hook write paths).
USER root
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      # Example: Postgres client headers for psycopg builds; graphviz for diagrams.
      libpq-dev graphviz \
 && rm -rf /var/lib/apt/lists/*
USER dev
