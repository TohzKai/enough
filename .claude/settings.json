{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "Kailash COC Claude (Python) - Claude Code hooks configuration",
  "effortLevel": "high",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "permissions": {
    "deny": [
      "Edit(.claude/learning/posture.json)",
      "Edit(.claude/learning/posture.json.bak)",
      "Edit(.claude/learning/posture.json.tmp.*)",
      "Edit(.claude/learning/violations.jsonl)",
      "Edit(.claude/learning/violations.jsonl.*)",
      "Edit(.claude/learning/.initialized)",
      "Write(.claude/learning/posture.json)",
      "Write(.claude/learning/posture.json.bak)",
      "Write(.claude/learning/posture.json.tmp.*)",
      "Write(.claude/learning/violations.jsonl)",
      "Write(.claude/learning/violations.jsonl.*)",
      "Write(.claude/learning/.initialized)",
      "MultiEdit(.claude/learning/posture.json)",
      "MultiEdit(.claude/learning/posture.json.bak)",
      "MultiEdit(.claude/learning/posture.json.tmp.*)",
      "MultiEdit(.claude/learning/violations.jsonl)",
      "MultiEdit(.claude/learning/violations.jsonl.*)",
      "MultiEdit(.claude/learning/.initialized)",
      "NotebookEdit(.claude/learning/posture.json)",
      "NotebookEdit(.claude/learning/posture.json.bak)",
      "NotebookEdit(.claude/learning/violations.jsonl)",
      "NotebookEdit(.claude/learning/.initialized)",
      "Edit(.claude/operators.roster.json)",
      "Write(.claude/operators.roster.json)",
      "MultiEdit(.claude/operators.roster.json)",
      "NotebookEdit(.claude/operators.roster.json)",
      "Edit(.claude/learning/coordination-log.jsonl)",
      "Write(.claude/learning/coordination-log.jsonl)",
      "MultiEdit(.claude/learning/coordination-log.jsonl)",
      "NotebookEdit(.claude/learning/coordination-log.jsonl)",
      "Bash(rm:.claude/learning/posture*)",
      "Bash(rm:.claude/learning/violations*)",
      "Bash(rm:.claude/learning/.initialized)",
      "Bash(rm:.claude/learning/.initialized*)",
      "Bash(mv:.claude/learning/posture*)",
      "Bash(mv:.claude/learning/violations*)",
      "Bash(mv:.claude/learning/.initialized)",
      "Bash(mv:.claude/learning/.initialized*)",
      "Bash(cp*.claude/learning/posture*)",
      "Bash(cp*.claude/learning/violations*)",
      "Bash(tee*.claude/learning/posture*)",
      "Bash(tee*.claude/learning/violations*)",
      "Bash(sed*.claude/learning/posture*)",
      "Bash(sed*.claude/learning/violations*)",
      "Bash(echo*.claude/learning/posture*)",
      "Bash(echo*.claude/learning/violations*)",
      "Bash(cp*.claude/learning/.initialized*)",
      "Bash(tee*.claude/learning/.initialized*)",
      "Bash(sed*.claude/learning/.initialized*)",
      "Bash(echo*.claude/learning/.initialized*)",
      "Bash(rm:.claude/operators.roster.json)",
      "Bash(rm*.claude/operators.roster.json*)",
      "Bash(mv:.claude/operators.roster.json)",
      "Bash(mv*.claude/operators.roster.json*)",
      "Bash(cp*.claude/operators.roster.json*)",
      "Bash(tee*.claude/operators.roster.json*)",
      "Bash(sed*.claude/operators.roster.json*)",
      "Bash(echo*.claude/operators.roster.json*)",
      "Bash(rm:.claude/learning/coordination-log.jsonl)",
      "Bash(rm*.claude/learning/coordination-log.jsonl*)",
      "Bash(mv:.claude/learning/coordination-log.jsonl)",
      "Bash(mv*.claude/learning/coordination-log.jsonl*)",
      "Bash(cp*.claude/learning/coordination-log.jsonl*)",
      "Bash(tee*.claude/learning/coordination-log.jsonl*)",
      "Bash(sed*.claude/learning/coordination-log.jsonl*)",
      "Bash(echo*.claude/learning/coordination-log.jsonl*)",
      "Bash(python*.claude/learning/posture*)",
      "Bash(python*.claude/learning/violations*)",
      "Bash(python*.claude/learning/.initialized*)",
      "Bash(python*.claude/operators.roster.json*)",
      "Bash(python*.claude/learning/coordination-log.jsonl*)",
      "Bash(python3*.claude/learning/posture*)",
      "Bash(python3*.claude/learning/violations*)",
      "Bash(python3*.claude/learning/.initialized*)",
      "Bash(python3*.claude/operators.roster.json*)",
      "Bash(python3*.claude/learning/coordination-log.jsonl*)",
      "Bash(node*.claude/learning/posture*)",
      "Bash(node*.claude/learning/violations*)",
      "Bash(node*.claude/learning/.initialized*)",
      "Bash(node*.claude/operators.roster.json*)",
      "Bash(node*.claude/learning/coordination-log.jsonl*)",
      "Edit(.claude/learning/.heartbeat-cache*)",
      "Write(.claude/learning/.heartbeat-cache*)",
      "MultiEdit(.claude/learning/.heartbeat-cache*)",
      "NotebookEdit(.claude/learning/.heartbeat-cache*)",
      "Bash(rm:.claude/learning/.heartbeat-cache*)",
      "Bash(mv:.claude/learning/.heartbeat-cache*)",
      "Bash(cp*.claude/learning/.heartbeat-cache*)",
      "Bash(tee*.claude/learning/.heartbeat-cache*)",
      "Bash(sed*.claude/learning/.heartbeat-cache*)",
      "Bash(echo*.claude/learning/.heartbeat-cache*)",
      "Edit(.claude/learning/.session-end-cache*)",
      "Write(.claude/learning/.session-end-cache*)",
      "MultiEdit(.claude/learning/.session-end-cache*)",
      "NotebookEdit(.claude/learning/.session-end-cache*)",
      "Bash(rm:.claude/learning/.session-end-cache*)",
      "Bash(mv:.claude/learning/.session-end-cache*)",
      "Bash(cp*.claude/learning/.session-end-cache*)",
      "Bash(tee*.claude/learning/.session-end-cache*)",
      "Bash(sed*.claude/learning/.session-end-cache*)",
      "Bash(echo*.claude/learning/.session-end-cache*)"
    ],
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(cp:*)",
      "Bash(git:*)",
      "Bash(node:*)",
      "Bash(yq:*)",
      "Bash(jq:*)",
      "Bash(md5:*)",
      "Bash(rm:.claude/test-harness/*)",
      "Bash(rm -rf .claude/test-harness*)",
      "Edit(.claude/**)",
      "Write(.claude/**)",
      "Read(.claude/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-bash-command.js\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/posture-gate.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/genesis-anchor-guard.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/signing-mutation-guard.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/operator-gate.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/gitignored-claude-warn.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/posture-gate.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/integrity-guard.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/adjacency-leasecheck.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/signing-mutation-guard.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/journal-write-guard.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/operator-gate.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/detect-violations.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read|Grep|Glob|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/probe-phase-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/adjacency-heartbeat.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/provenance-capture-tool.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/detect-violations.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/fold-amendment-paired-with-helper.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-workflow.js\"",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-deployment.js\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/integration-hygiene.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto-format.js\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-framework-first.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/detect-violations.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.js\""
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/posture-gate.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/multi-operator-sessionstart.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-end.js\""
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/multi-operator-sessionend.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-compact.js\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/user-prompt-rules-reminder.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/detect-violations.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/provenance-capture-prompt.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/log-triage-gate.js\"",
            "timeout": 7
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/adjacency-heartbeat.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/multi-operator-sessionend.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/detect-violations.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
